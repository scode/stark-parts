            {
              code: "43_wiring_harness",
              display_name: "Wiring harness",
              description: "This is the main harness for the bike that goes into the VCU, to the inverter to the map switch to the throttle. It is the nerve system of the bike and is sourced from Spanish electronic firm Apta. The wiring is different diameter depending on the role and purpose of each part.",
              localization_key: "spare_parts_product_43_wiring_harness_name",
